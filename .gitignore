!.env.example

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Claude Code ─────────────────────────────────────────────────────────────
.claude/

# ─── OS artifacts ─────────────────────────────────────────────────────────────
